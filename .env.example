# Docker (default) — API connects to the 'db' service inside the Docker network
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/markdown_editor
JWT_SECRET=                    # required — any random string, e.g. openssl rand -hex 32
ALLOWED_ORIGINS=http://localhost

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=markdown_editor

# Dev (make dev + pnpm dev) — API runs on host, so use localhost instead of 'db'
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/markdown_editor
# ALLOWED_ORIGINS=http://localhost:5173
