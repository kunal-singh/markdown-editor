{
  "name": "markdown-editor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "dev": "pnpm --filter @markdown-editor/app dev",
    "build": "pnpm --filter @markdown-editor/app build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "pnpm --filter @markdown-editor/app typecheck"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@kunal-singh/commitlint-config": "^0.1.1",
    "@kunal-singh/eslint-config": "^0.2.4",
    "@kunal-singh/prettier-config": "^0.1.1",
    "@kunal-singh/typescript-config": "^0.2.3",
    "@types/node": "^24.12.0",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^6.1.1",
    "lefthook": "^2.1.4",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook"
    ]
  }
}
